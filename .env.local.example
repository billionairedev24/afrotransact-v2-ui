# =============================================================================
# AfroTransact Web — environment variables template
# =============================================================================
# Copy to .env.local for local dev. For Vercel / K8s deploys, these are set
# via `refined/infrastructure/scripts/setup-vercel-env.sh` or the K8s secret
# attached to the UI Deployment.
# =============================================================================

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=super-secret-dev-key-change-in-production

# ── Keycloak (public afrotransact-web client) ───────────────────────────────
KEYCLOAK_CLIENT_ID=afrotransact-web
KEYCLOAK_CLIENT_SECRET=afrotransact-web-secret
# Issuer URLs:
# - KEYCLOAK_ISSUER: public realm URL — must match redirect / logout URLs browsers use (`iss`
#   in tokens is usually this hostname). NEXTAUTH/OAuth redirects point here (`/auth`, `/registrations`).
# - KEYCLOAK_ISSUER_SERVER (optional): URL the Next.js *server* uses for token/JWKS/admin REST calls.
#   When unset, it defaults to KEYCLOAK_ISSUER. Use an in-cluster hostname (e.g.
#   http://keycloak:8080/realms/afrotransact) when public HTTPS resets from Node (ECONNRESET)
#   but browsers reach the external issuer.
#
# Issuer MUST be reachable from the user's browser. Token exchange reaches KEYCLOAK_ISSUER_SERVER
# (Docker: avoid https://external... from inside the UI container unless routing is wired).
KEYCLOAK_ISSUER=http://localhost:8180/realms/afrotransact
# KEYCLOAK_ISSUER_SERVER=http://keycloak:8080/realms/afrotransact
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8180/realms/afrotransact
# Optional override. Code defaults to "afrotransact". Set only if your realm
# name differs from the default.
KEYCLOAK_REALM=afrotransact

# ── Keycloak internal verify client (server-to-server password verification) ─
# Server-side-only Keycloak client with Direct Access Grants enabled.
# Used for current-password verification in the change-password flow.
KEYCLOAK_VERIFY_CLIENT_ID=afrotransact-internal
KEYCLOAK_VERIFY_CLIENT_SECRET=afrotransact-internal-secret

# ── Keycloak admin-api service account (server-side only) ────────────────────
# Used by the Next.js BFF for Keycloak Admin operations (password reset,
# account deletion, seller role grant) via client_credentials grant.
# Preferred over username/password.
# Optional override. Code defaults to "afrotransact-admin-api".
KEYCLOAK_ADMIN_API_CLIENT_ID=afrotransact-admin-api
# Generate with: openssl rand -base64 32
KEYCLOAK_ADMIN_API_SECRET=

# Legacy/fallback: direct admin credentials against the master realm (only
# used when ADMIN_API_SECRET is not set). Avoid in production.
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=
# Optional override. Code defaults to "admin-cli".
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=

# ── Checkout ─────────────────────────────────────────────────────────────────
# Delivery ETA shown on shipping options ("Arrives in N hours"). Defaults to 48.
NEXT_PUBLIC_DELIVERY_ETA_HOURS=48

# ── Gateway / API ────────────────────────────────────────────────────────────
# Public (browser-reachable) gateway URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
# Optional: cluster-internal base URL used by server components / route handlers.
# Falls back to NEXT_PUBLIC_API_URL when unset. In K8s, point this at the in-cluster
# gateway DNS (e.g. http://gateway.afrotransact.svc.cluster.local:8080).
INTERNAL_API_URL=
API_URL=

# Public site URL (used for canonical/metadata links).
# Prod: https://www.afrotransact.com  ·  UAT: https://uat.afrotransact.com
# Prod backend hostnames follow `*.prod.afrotransact.com`:
#   NEXTAUTH_URL=https://www.afrotransact.com
#   NEXT_PUBLIC_API_URL=https://api.prod.afrotransact.com
#   KEYCLOAK_ISSUER=https://auth.prod.afrotransact.com/realms/afrotransact
#   NEXT_PUBLIC_KEYCLOAK_ISSUER=https://auth.prod.afrotransact.com/realms/afrotransact
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Used by server-side password/reset flows that need an absolute URL.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── AI chatbot (AI-INTEGRATION) ──────────────────────────────────────────────
# Master AI gate. When false the floating AiWidget, the "For You" homepage
# recommendations rail, and any other AI-backed surfaces are hidden, and no
# requests are made to the ai service / /api/v1/ai/* endpoints.
# AFT-1 (beta launch): MUST be "false" in production until AI is ready.
NEXT_PUBLIC_AI_ENABLED=false

# Dedicated chatbot/Victory floating widget gate. Currently the AiWidget honors
# NEXT_PUBLIC_AI_ENABLED; this var is reserved so the chatbot can be toggled
# independently of the rest of AI (e.g. enable recommendations but keep chat
# hidden). Components SHOULD treat unset / "false" as hidden.
NEXT_PUBLIC_CHATBOT_ENABLED=false

# ── WhatsApp support FAB ────────────────────────────────────────────────────
# E.164 phone number (with country code, including the leading "+") used by the
# floating WhatsApp chat button on customer-facing pages. Example: +15551234567.
# Leave blank / unset to hide the widget entirely (no broken wa.me link).
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key only — NEVER the secret key.
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ── Region / Shipping ────────────────────────────────────────────────────────
# Must match a region code in the config service. Falls back to first active region if unset.
NEXT_PUBLIC_DEFAULT_REGION_CODE=us-tx-austin

# Real (live carrier) shipping master gate. The authoritative switch is the
# admin "shipping_realtime_enabled" platform setting (config service, see
# services/config/migrations/000011_disable_realtime_shipping.up.sql which
# seeds it to false in prod). This env var is a frontend belt-and-suspenders
# so checkout UI defaults to flat-rate / synthetic quotes even if the admin
# setting is wrong. AFT-1 (beta launch): MUST be "false" in production.
NEXT_PUBLIC_REAL_SHIPPING_ENABLED=false

# ── Closed beta buyer gate (Next.js proxy.ts → “Proxy”) ───────────────────────
# When BETA_GATE_ENABLED=true and BETA_INVITE_SECRET is set, browsers must redeem
# the secret once via POST /api/beta-invite (see /invite) before storefront routes load.
BETA_GATE_ENABLED=false
BETA_INVITE_SECRET=

# ── Google Maps (address autocomplete, checkout, store setup) ───────────────
# Enable "Places API" and "Maps JavaScript API" in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── UploadThing (logo/banner/document uploads) ──────────────────────────────
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your_uploadthing_token_here
# Optional: override the callback URL UploadThing posts to (useful behind tunnels/ingress).
UPLOADTHING_CALLBACK_URL=

# ── Security headers ────────────────────────────────────────────────────────
# Set to "true" in UAT/prod behind HTTPS ingress; adds HSTS and strict CSP.
ENFORCE_HTTPS=false
