NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=super-secret-dev-key-change-in-production
KEYCLOAK_CLIENT_ID=afrotransact-web
KEYCLOAK_CLIENT_SECRET=afrotransact-web-secret
KEYCLOAK_ISSUER=http://localhost:8180/realms/afrotransact
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8180/realms/afrotransact
NEXT_PUBLIC_API_URL=http://localhost:8080

# Stripe — use your publishable key (NEVER the secret key in frontend env)
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Default region code used for checkout, pricing, and feature flags.
# Must match a region code in the config service. Falls back to the first active region if unset.
NEXT_PUBLIC_DEFAULT_REGION_CODE=us-tx-austin

# Google Maps / Places — for address autocomplete in checkout and store setup
# Get from https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API" for your project
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# UploadThing — for file uploads (logo, banner, documents)
# Get from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your_uploadthing_token_here
